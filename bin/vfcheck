#!/bin/bash
set -e

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  echo "usage: vfcheck <directory> [filter]"
  exit 1
fi

DIR="$1"
FILTER="${2:-}"
BULLET="../bullet/target/release/bullet-utils"

if [ ! -x "$BULLET" ]; then
  echo "error: bullet-utils not found at $BULLET"
  exit 1
fi

TOTAL_GAMES=0
TOTAL_POSITIONS=0
TOTAL_FILES=0
FAILED=0

for f in "$DIR"/*.vf; do
  [ -f "$f" ] || continue
  if [ -n "$FILTER" ] && [[ "$(basename "$f")" != *"$FILTER"* ]]; then
    continue
  fi
  TOTAL_FILES=$((TOTAL_FILES + 1))

  # check file ends with 4-byte zero terminator (end-of-game marker)
  TAIL=$(tail -c 4 "$f" | od -An -tx1 | tr -d ' \n')
  if [ "$TAIL" != "00000000" ]; then
    echo "FAIL $f (truncated: missing end-of-game marker)"
    FAILED=$((FAILED + 1))
    continue
  fi

  OUTPUT=$("$BULLET" viribinpack count "$f" 2>&1) || {
    echo "FAIL $f"
    FAILED=$((FAILED + 1))
    continue
  }
  GAMES=$(echo "$OUTPUT" | grep "^Games" | awk '{print $3}')
  POSITIONS=$(echo "$OUTPUT" | grep "^Positions" | awk '{print $3}')
  BPP=$(echo "$OUTPUT" | grep "^Bytes" | awk '{print $5}')
  echo "ok   $f  games=$GAMES positions=$POSITIONS bpp=$BPP"
  TOTAL_GAMES=$((TOTAL_GAMES + GAMES))
  TOTAL_POSITIONS=$((TOTAL_POSITIONS + POSITIONS))
done

if [ "$TOTAL_FILES" -eq 0 ]; then
  echo "no .vf files found in $DIR"
  exit 1
fi

echo ""
echo "$TOTAL_FILES files, $TOTAL_GAMES games, $TOTAL_POSITIONS positions, $FAILED failed"

if [ "$FAILED" -gt 0 ]; then
  exit 1
fi
